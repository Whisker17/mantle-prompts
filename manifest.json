      "id": "pr.adversarial-review",
      "title": "PR Adversarial Review",
      "description": "Serial, high-intensity adversarial pull request review prompts for CI/action workflows.",
      "defaultVersion": "v2",
      "versions": {
        "v1": {
          "status": "archived",
          "createdAt": "2026-04-30",
          "source": "Extracted as-is from the active Mantle agent scaffold .github/prompts files.",
          "requiredPlaceholders": [
            {
              "name": "__PR_NUMBER__",
              "description": "GitHub pull request number."
            },
            {
              "name": "__REPO__",
              "description": "GitHub repository in owner/name form."
            }
          ],
          "prompts": [
            {
              "id": "pr.adversarial-review.v1.codex-initial",
              "stage": 1,
              "agent": "codex",
              "path": "prompts/pr/adversarial-review/v1/codex-initial-review.md",
              "requiredTools": ["gh", "rg"],
              "summaryMarker": "CODEX_INITIAL_REVIEW_SUMMARY",
              "description": "Initial Codex adversarial review before Claude has reviewed the workflow run."
            },
            {
              "id": "pr.adversarial-review.v1.claude-second-pass",
              "stage": 2,
              "agent": "claude",
              "path": "prompts/pr/adversarial-review/v1/claude-second-pass-review.md",
              "requiredTools": ["gh", "mcp__github_inline_comment__create_inline_comment"],
              "summaryMarker": "CLAUDE_REVIEW_SUMMARY",
              "description": "Claude adversarial review and cross-review of Codex initial findings."
            },
            {
              "id": "pr.adversarial-review.v1.codex-final",
              "stage": 3,
              "agent": "codex",
              "path": "prompts/pr/adversarial-review/v1/codex-final-review.md",
              "requiredTools": ["gh", "rg"],
              "summaryMarker": "CODEX_FINAL_REVIEW_SUMMARY",
              "description": "Final Codex adversarial review after Claude, including disposition of Claude findings and replies."
            }
          ]
        },
        "v2": {
          "status": "active",
          "createdAt": "2026-05-01",
          "source": "Genericized from v1 with repository-specific context moved into profiles/repositories.",
          "requiredPlaceholders": [
            {
              "name": "{{PR_NUMBER}}",
              "description": "GitHub pull request number."
            },
            {
              "name": "{{REPO}}",
              "description": "GitHub repository in owner/name form."
            },
            {
              "name": "{{TARGET_LABEL}}",
              "description": "Human-readable target label, for example `PR #123 in owner/repo`."
            },
            {
              "name": "{{USER_FOCUS}}",
              "description": "Repo-specific review emphasis, usually loaded from a repository profile."
            },
            {
              "name": "{{REPOSITORY_PROFILE}}",
              "description": "Repo-specific durable context, usually loaded from a repository profile."
            }
          ],
          "profileVariables": [
            {
              "name": "{{USER_FOCUS}}",
              "defaultSource": "variables.USER_FOCUS"
            },
            {
              "name": "{{REPOSITORY_PROFILE}}",
              "defaultSource": "variables.REPOSITORY_PROFILE"
            }
          ],
          "prompts": [
            {
              "id": "pr.adversarial-review.v2.codex-initial",
